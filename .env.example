# ─── Backend ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: https://app.supabase.com → your project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# For local Supabase dev (supabase start):
# SUPABASE_URL=http://localhost:54321
# SUPABASE_SERVICE_ROLE_KEY=<output of `supabase status`>

# ─── Redis (Upstash) ─────────────────────────────────────────────────────────
# Get from: https://console.upstash.com → your database → REST API
# Leave empty to use in-memory LRU cache (development only)
REDIS_URL=

# ─── DeepL (Translation Fallback) ────────────────────────────────────────────
# Free tier (500K chars/month): https://www.deepl.com/pro-api
# Free tier uses api-free.deepl.com — NOT api.deepl.com
DEEPL_API_KEY=
DEEPL_API_URL=https://api-free.deepl.com/v2

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,chrome-extension://
