# ─── Backend ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: https://app.supabase.com → your project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# For local Supabase dev (supabase start):
# SUPABASE_URL=http://localhost:54321
# SUPABASE_SERVICE_ROLE_KEY=<output of `supabase status`>

# ─── Redis (Upstash) ─────────────────────────────────────────────────────────
# Get from: https://console.upstash.com → your database → REST API
# Leave empty to use in-memory LRU cache (development only)
REDIS_URL=

# ─── MyMemory (Translation Fallback) ────────────────────────────────────────
# Completely free, no credit card needed.
# Without email: 1K words/day. With email: 10K words/day.
# Register at: https://mymemory.translated.net
MYMEMORY_EMAIL=

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,chrome-extension://
