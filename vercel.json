{
  "buildCommand": "pnpm turbo run build --filter=@lexaflow/pwa...",
  "outputDirectory": "packages/pwa/dist",
  "installCommand": "pnpm install",
  "framework": null,
  "rewrites": [
    { "source": "/api/words/export", "destination": "/api/words/export" },
    { "source": "/api/words/:id",    "destination": "/api/words/[id]" },
    { "source": "/api/words",        "destination": "/api/words/index" },
    { "source": "/api/lookup",       "destination": "/api/lookup" },
    { "source": "/api/health",       "destination": "/api/health" },
    { "source": "/(.*)",             "destination": "/index.html" }
  ]
}
